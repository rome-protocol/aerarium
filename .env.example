# EXAMPLE env. Aerarium is chain-agnostic: it resolves the real chain config —
# addresses, RPC, explorer, program id, Multicall3, cluster — from the Rome
# registry (→ lib/registry/generated.json), NOT from this file. Swap chains with
# NEXT_PUBLIC_DEFAULT_CHAIN_ID (any chain that has an apps/compound/<id>-<slug>
# registry entry) and rebuild — no code change. The values below are Hadrian
# (200010) as a worked example; the per-contract NEXT_PUBLIC_* vars are optional
# dev overrides (the registry is the source of truth).
NEXT_PUBLIC_DEFAULT_CHAIN_ID=200010
NEXT_PUBLIC_ROME_RPC=https://hadrian.testnet.romeprotocol.xyz/

# --- Solana-native lane (Phantom, no ETH key) ---
# ALT pointer registry (programs/alt-registry): deterministic (authority,comet)->ALT
# so a returning user rediscovers their Address Lookup Table cross-device via one
# getAccountInfo (no localStorage). Defaults to the deployed id if unset.
NEXT_PUBLIC_ALT_REGISTRY_PROGRAM=2qQwRVKpVswDZQWawug5uybWwEdTYZJmdFvsGMjvPkfB

# --- Solana lane infra endpoints (SERVER-SIDE, runtime, never inlined) ---
# These are read server-side at runtime (NOT NEXT_PUBLIC_, so they're never
# baked into the build / shipped to the browser). The browser talks only to the
# same-origin proxy routes; these are the upstreams those routes forward to.
# One image runs against devnet/testnet/mainnet by swapping these in .env.
# REQUIRED in production (validateEnv fails fast at boot if either is missing).
#
# SOLANA_RPC — the (private) Solana RPC the /api/solana-rpc proxy forwards the
#   DoTxUnsigned to (getLatestBlockhash → sendRawTransaction → getSignatureStatuses).
#   Use the public devnet endpoint for local dev, your private RPC in a deploy.
SOLANA_RPC=https://api.devnet.solana.com
# DISCOVERY_PROXY_UPSTREAM — the rome_emulateCallAccounts upstream the
#   /api/discovery proxy forwards to. The deployed rome Proxy now serves this RPC
#   (the Rome proxy #362); for a single_state chain the public RPC endpoint IS the
#   proxy, so set this to the chain's RPC host (same as ROME_RPC_UPSTREAM).
#   Falls back to localhost:9090 for a locally-run proxy in dev.
DISCOVERY_PROXY_UPSTREAM=http://localhost:9090
# Dev-only shortcut: bypass the /api/solana-rpc proxy and submit straight to an
# absolute RPC from the browser. Overrides SOLANA_RPC for the client connection.
# Do NOT set in production (would inline into the bundle). Leave unset normally.
# NEXT_PUBLIC_SOLANA_RPC=

# WalletConnect (Reown) project ID — required for RainbowKit wallet connect.
# Create at https://cloud.reown.com and allowlist your demo origin.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Headless mock-wallet mode (Playwright smoke + dev). Optional. ---
# When NEXT_PUBLIC_MOCK_WALLET=1, the demo skips RainbowKit / MetaMask and
# auto-connects as MOCK_WALLET_ADDRESS.  Reads forward to Hadrian's RPC;
# eth_sendTransaction is signed locally with MOCK_WALLET_PRIVATE_KEY then
# submitted as eth_sendRawTransaction.  Testnet-only — privkey lands in
# the client bundle, do NOT point this at a funded mainnet account.
# NEXT_PUBLIC_MOCK_WALLET=1
# NEXT_PUBLIC_MOCK_WALLET_ADDRESS=0x9c9Fd89c8d34a61106b3F9Db41733B02b827c9B5
# NEXT_PUBLIC_MOCK_WALLET_PRIVATE_KEY=0x...
